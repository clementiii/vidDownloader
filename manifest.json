{
  "manifest_version": 3,
  "name": "Video Detector & Downloader",
  "version": "1.0.0",
  "description": "Detects and downloads videos from any webpage",
  "author": "Video Downloader",
  "homepage_url": "https://github.com/video-downloader",
  "key": "",
  
  "permissions": [
    "activeTab",
    "downloads",
    "webRequest",
    "storage",
    "notifications",
    "nativeMessaging"
  ],

  "host_permissions": [
    "<all_urls>"
  ],
  
  "icons": {
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  },
  
  "action": {
    "default_icon": {
      "48": "icons/icon-48.svg",
      "96": "icons/icon-96.svg"
    },
    "default_title": "Video Downloader",
    "default_popup": "popup/popup.html"
  },
  
  "background": {
    "service_worker": "background/service_worker.js"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/browser-api.js", "content/content.js"],
      "run_at": "document_end"
    }
  ],
  
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
