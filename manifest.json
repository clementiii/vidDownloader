{
  "manifest_version": 2,
  "name": "Video Detector & Downloader",
  "version": "1.0.0",
  "description": "Detects and downloads videos from any webpage",
  "author": "Video Downloader",
  "homepage_url": "https://github.com/video-downloader",
  
  "browser_specific_settings": {
    "gecko": {
      "id": "viddownloader@example.com",
      "strict_min_version": "57.0"
    }
  },
  
  "permissions": [
    "activeTab",
    "downloads",
    "webRequest",
    "webRequestBlocking",
    "storage",
    "notifications",
    "nativeMessaging",
    "<all_urls>"
  ],
  
  "icons": {
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  },
  
  "browser_action": {
    "default_icon": {
      "48": "icons/icon-48.svg",
      "96": "icons/icon-96.svg"
    },
    "default_title": "Video Downloader",
    "default_popup": "popup/popup.html"
  },
  
  "background": {
    "scripts": ["background/background.js"],
    "persistent": true
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_end"
    }
  ],
  
  "web_accessible_resources": [
    "icons/*"
  ]
}
